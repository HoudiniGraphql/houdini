{
	"exclude": ["node_modules", "packages/*/build/**"],
	"include": ["packages/**/*.ts", "packages/**/*.tsx", "houdini.d.ts"],
	"compilerOptions": {
		"moduleResolution": "node",
		"module": "es2020",
		"lib": ["ES2021", "DOM", "ES2021.String"],
		"target": "ESNext",
		"isolatedModules": true,
		"resolveJsonModule": true,
		"sourceMap": false,
		"declaration": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"downlevelIteration": true,
		"emitDeclarationOnly": true,
		"baseUrl": "./packages/houdini",
		"paths": {
			"$houdini/runtime": ["../houdini-core/runtime"],
			"$houdini/runtime/*": ["../houdini-core/runtime/*"],
			"houdini": ["../houdini/src/lib"],
			"houdini/*": ["../houdini/src/*"],
			"houdini/vite": ["../houdini/src/vite"],
			"houdini/test": ["../houdini/src/test"],
			"houdini-core/*": ["../houdini-core/*"],
			"houdini-svelte/*": ["../houdini-svelte/package/lib/*"],
			"houdini-svelte": ["../houdini-svelte/package/lib"]
		},
		"jsx": "react-jsx"
	}
}
