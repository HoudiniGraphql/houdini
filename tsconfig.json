{
	"exclude": ["node_modules", "packages/*/build/**"],
	"include": ["packages/**/*.ts", "packages/**/*.tsx", "houdini.d.ts"],
	"compilerOptions": {
		"moduleResolution": "bundler",
		"module": "preserve",
		"lib": ["ES2021", "DOM", "ES2021.String"],
		"target": "ESNext",
		"isolatedModules": true,
		"resolveJsonModule": true,
		"sourceMap": false,
		"declaration": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowJs": true,
		"checkJs": true,
		"emitDeclarationOnly": true,
		"paths": {
			"$houdini/runtime": ["./packages/houdini-core/runtime"],
			"$houdini/runtime/*": ["./packages/houdini-core/runtime/*"],
			"houdini": ["./packages/houdini/src/lib"],
			"houdini/*": ["./packages/houdini/src/*"],
			"houdini/vite": ["./packages/houdini/src/vite"],
			"houdini/test": ["./packages/houdini/src/test"],
			"houdini-core/*": ["./packages/houdini-core/*"],
			"houdini-svelte/*": ["./packages/houdini-svelte/package/lib/*"],
			"houdini-svelte": ["./packages/houdini-svelte/package/lib"]
		},
		"jsx": "react-jsx"
	}
}
