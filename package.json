{
	"name": "houdini-monorepo",
	"private": true,
	"version": "1.0.0",
	"description": "The disappearing graphql client for SvelteKit",
	"type": "module",
	"scripts": {
		"tests": "vitest",
		"tests:ui": "vitest --ui --coverage",
		"test": "pnpm run tests",
		"bench": "vitest bench packages/houdini/src/runtime/cache/benchmarks/ --outputJson perf/benchmark.json",
		"bench:check": "vitest bench packages/houdini/src/runtime/cache/benchmarks/ --outputJson perf/benchmark.current.json && node perf/compare.js",
		"bench:quick": "BENCH_QUICK=1 vitest bench packages/houdini/src/runtime/cache/benchmarks/ --outputJson perf/benchmark.quick.json",
		"watch-bench": "sh perf/watch-bench.sh",
		"build:all": "turbo build",
		"build": "turbo run build --filter=\"./packages/*\"",
		"dev": "turbo dev --filter=\"./packages/*\"",
		"compile:all": "turbo compile",
		"compile": "turbo compile --filter=\"./packages/*\"",
		"typedefs:all": "turbo run typedefs",
		"typedefs": "turbo run typedefs --filter=\"./packages/*\"",
		"lint": "biome lint",
		"format": "biome format --write",
		"format:check": "biome format",
		"release": "pnpm run build && node packages/_scripts/release.js",
		"release:snapshot": "pnpm run build && node packages/_scripts/release.js --snapshot",
		"version": "changeset version",
		"version:ci": "bash -lc 'for attempt in 1 2 3; do pnpm run version && exit 0; if [ \"$attempt\" -lt 3 ]; then echo \"changeset version failed, retrying in $((attempt * 5))s...\"; sleep $((attempt * 5)); fi; done; exit 1'"
	},
	"devDependencies": {
		"@babel/plugin-syntax-import-assertions": "^7.29.7",
		"@biomejs/biome": "^2.4.16",
		"@changesets/changelog-git": "^0.2.1",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.60.0",
		"@types/react": "^19.2.16",
		"@vitest/coverage-v8": "^4.1.8",
		"@vitest/ui": "^4.1.8",
		"graphql": "^16.14.1",
		"lint-staged": "^17.0.7",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"fs-extra": "^11.3.5",
		"jest-snapshot": "^30.4.1",
		"memfs": "^4.17.2",
		"recast": "^0.23.11",
		"rollup": "^4.61.1"
	},
	"packageManager": "pnpm@11.5.2",
	"lint-staged": {
		"*.{ts,tsx,js,json}": "biome format --write"
	}
}
