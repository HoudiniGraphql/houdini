{
    "name": "houdini-adapter-static",
    "version": "2.0.0-next.34",
    "description": "The adapter for deploying your Houdini application as a single-page application without a server component",
    "keywords": [
        "houdini",
        "adpter",
        "node"
    ],
    "homepage": "https://github.com/HoudiniGraphql/houdini",
    "funding": "https://github.com/sponsors/HoudiniGraphql",
    "repository": {
        "type": "git",
        "url": "https://github.com/HoudiniGraphql/houdini.git"
    },
    "license": "MIT",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "npx tsc src/* --allowJs --outDir build --module esnext --moduleResolution bundler --target esnext --allowSyntheticDefaultImports --declaration --skipLibCheck || exit 0 ",
        "build:": "cd ../../ && ((run build && cd -) || (cd - && exit 1))",
        "build:build": "pnpm build: && pnpm build"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@types/react-dom": "^19.2.3",
        "csstype": "^3.2.3",
        "houdini": "workspace:^",
        "scripts": "workspace:^",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "undici-types": "^8.3.0"
    },
    "dependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "peerDependencies": {
        "houdini": "workspace:^",
        "vite": "^8.0.0"
    },
    "files": [
        "build"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": "./build/index.js",
            "require": "./build/index.cjs"
        }
    },
    "types": "./build/index.d.ts",
    "typesVersions": {
        "*": {
            "app": [
                "./build/app.d.ts"
            ]
        }
    }
}
