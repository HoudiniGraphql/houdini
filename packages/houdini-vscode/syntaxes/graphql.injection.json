{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "inline.graphql.houdini",
    "injectionSelector": "L:source.ts -comment -string, L:source.tsx -comment -string, L:source.js -comment -string, L:source.jsx -comment -string, L:source.svelte -comment -string",
    "patterns": [
        {
            "comment": "graphql(`...`) call",
            "begin": "(graphql)\\s*(\\()\\s*(`)",
            "beginCaptures": {
                "1": { "name": "entity.name.function.ts" },
                "2": { "name": "meta.brace.round.ts" },
                "3": { "name": "punctuation.definition.string.template.begin.ts" }
            },
            "end": "(`)",
            "endCaptures": {
                "1": { "name": "punctuation.definition.string.template.end.ts" }
            },
            "contentName": "meta.embedded.block.graphql",
            "patterns": [{ "include": "source.graphql" }]
        },
        {
            "comment": "component field prop: GraphQL<`...`>",
            "begin": "(GraphQL)\\s*(<)\\s*(`)",
            "beginCaptures": {
                "1": { "name": "entity.name.type.ts" },
                "2": { "name": "punctuation.definition.typeparameters.begin.ts" },
                "3": { "name": "punctuation.definition.string.template.begin.ts" }
            },
            "end": "(`)",
            "endCaptures": {
                "1": { "name": "punctuation.definition.string.template.end.ts" }
            },
            "contentName": "meta.embedded.block.graphql",
            "patterns": [{ "include": "source.graphql" }]
        }
    ]
}
