{
    "name": "houdini-react",
    "version": "2.0.0-next.44",
    "description": "The React plugin for houdini",
    "keywords": [
        "typescript",
        "react",
        "graphql",
        "graphql-client"
    ],
    "homepage": "https://github.com/HoudiniGraphql/houdini",
    "funding": "https://github.com/sponsors/HoudiniGraphql",
    "repository": {
        "type": "git",
        "url": "https://github.com/HoudiniGraphql/houdini.git"
    },
    "license": "MIT",
    "scripts": {
        "compile": "scripts build-go",
        "typedefs": "scripts typedefs --plugin --go-package"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/cookie-session": "^2.0.49",
        "@types/cookies": "^0.9.2",
        "@types/estraverse": "^5.1.7",
        "@types/express": "^5.0.3",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "scripts": "workspace:^"
    },
    "dependencies": {
        "@babel/parser": "^7.29.7",
        "@babel/types": "^7.29.7",
        "@whatwg-node/server": "^0.11.0",
        "cookie-parser": "^1.4.7",
        "cookie-session": "^2.1.1",
        "cookies": "^0.9.1",
        "estraverse": "^5.3.0",
        "express": "^5.1.0",
        "graphql-yoga": "^5.21.1",
        "houdini": "workspace:^",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-streaming": "^0.4.17",
        "recast": "^0.23.11",
        "rollup": "^4.61.1",
        "use-deep-compare-effect": "^1.8.1"
    },
    "peerDependencies": {
        "graphql": ">=16"
    },
    "files": [
        "build"
    ],
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./build/plugin/index.d.ts",
            "import": "./build/plugin-esm/index.js",
            "require": "./build/plugin-cjs/index.js"
        },
        "./server": {
            "types": "./build/server/index.d.ts",
            "import": "./build/server-esm/index.js",
            "require": "./build/server-cjs/index.js"
        }
    },
    "typesVersions": {
        "*": {
            "server": [
                "./build/server/index.d.ts"
            ]
        }
    },
    "main": "./build/plugin-cjs/index.js",
    "types": "./build/plugin/index.d.ts"
}
