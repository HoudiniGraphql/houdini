{
	"name": "e2e-react",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build:": "cd ../../ && ((pnpm run build && cd -) || (cd - && exit 1))",
		"build:dev": "pnpm build: && pnpm dev",
		"build:test": "pnpm build: && pnpm test",
		"compile:dev": "pnpm run compile:core && pnpm run compile:houdini && pnpm run compile:react &&  pnpm dev",
		"compile:generate": "pnpm run compile:core && pnpm run compile:houdini && pnpm run compile:react &&  pnpm generate",
		"compile:core": "cd ../../packages/houdini-core && ((pnpm run compile && cd -) || (cd - && exit 1))",
		"compile:core:generate": "pnpm run compile:core && pnpm houdini generate",
		"compile:core:dev": "pnpm run compile:core && pnpm dev",
		"compile:houdini": "cd ../../packages/houdini && ((pnpm run compile && cd -) || (cd - && exit 1))",
		"compile:houdini:generate": "pnpm run compile:houdini && pnpm houdini generate",
		"compile:houdini:dev": "pnpm run compile:houdini && pnpm dev",
		"compile:react": "cd ../../packages/houdini-react && ((pnpm run compile && cd -) || (cd - && exit 1))",
		"compile:react:generate": "pnpm run compile:react && pnpm houdini generate",
		"compile:react:dev": "pnpm run compile:react && pnpm dev",
		"generate": "pnpm houdini generate",
		"build:generate": "pnpm build: && pnpm houdini generate",
		"build:build": "pnpm build: && pnpm build",
		"houdini": "node ensureLinks.js && houdini",
		"dev": "node ./ensureLinks.js && vite dev",
		"build": "node ./ensureLinks.js && vite build",
		"tests": "npm run build && playwright test",
		"test": "npm run tests",
		"tw": "npx tailwindcss -i ./src/styles.css -o ./public/assets/output.css --watch",
		"preview": "vite dev",
		"preinstall": "node preInstall.js",
		"lint": "eslint ."
	},
	"dependencies": {
		"@cloudflare/workers-types": "^4.20260605.1",
		"@graphql-tools/schema": "^10.0.33",
		"@whatwg-node/server": "^0.11.0",
		"cookie": "^1.1.1",
		"e2e-api": "workspace:^",
		"graphql-yoga": "^5.21.1",
		"houdini": "workspace:^",
		"houdini-adapter-node": "workspace:^",
		"houdini-react": "workspace:^",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-streaming": "^0.4.17"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"@vitejs/plugin-react": "^6.0.2",
		"autoprefixer": "^10.5.0",
		"concurrently": "^10.0.3",
		"cross-env": "^10.1.0",
		"e2e-api": "workspace:^",
		"eslint": "^10.4.1",
		"hono": "^4.12.23",
		"postcss": "^8.5.15",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.98.0"
	}
}
